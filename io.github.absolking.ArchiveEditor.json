{
    "app-id": "io.github.absolking.ArchiveEditor",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "archive-editor",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home"
    ],
    "cleanup": [
        "*.pyc",
        "*.pyo",
        "__pycache__"
    ],
    "modules": [
        {
            "name": "archive-editor",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 archive-editor /app/bin/archive-editor",
                "install -Dm644 src/main.py            /app/share/archive-editor/main.py",
                "install -Dm644 src/application.py     /app/share/archive-editor/application.py",
                "install -Dm644 src/window.py          /app/share/archive-editor/window.py",
                "install -Dm644 src/archive_logic.py   /app/share/archive-editor/archive_logic.py",
                "install -Dm644 io.github.absolking.ArchiveEditor.desktop      /app/share/applications/io.github.absolking.ArchiveEditor.desktop",
                "install -Dm644 io.github.absolking.ArchiveEditor.metainfo.xml /app/share/metainfo/io.github.absolking.ArchiveEditor.metainfo.xml",
                "install -Dm644 io.github.absolking.ArchiveEditor.svg          /app/share/icons/hicolor/scalable/apps/io.github.absolking.ArchiveEditor.svg"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
